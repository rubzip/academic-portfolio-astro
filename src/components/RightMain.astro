---
import Navbar from "./Navbar.astro";
---

<div class="flex-1 min-w-0 bg-background transition-colors duration-300">
    <div class="px-8 md:px-16 lg:px-24 py-6 md:py-12">
        <Navbar />
        <main class="animate-in fade-in duration-700">
            <slot />
        </main>
    </div>
</div>

<style>
    /* Animation utility */
    .animate-in {
        animation: animate-in 0.5s ease-out;
    }
    @keyframes animate-in {
        from {
            opacity: 0;
            transform: translateY(10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>
