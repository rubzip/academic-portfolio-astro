---
import { SITE, SOCIALS } from "../config";
import { SOCIAL_ICONS } from "../constants";

const activeSocials = SOCIALS.filter((s) => s.active);
---

<aside
    class="w-[300px] h-screen sticky top-0 bg-sidebar-bg border-r border-border p-12 pt-[215px] flex flex-col justify-between shrink-0 max-md:w-full max-md:h-auto max-md:relative max-md:p-8 max-md:border-r-0 max-md:border-b transition-colors duration-300"
>
    <div class="sidebar-header flex flex-col items-center text-center">
        {
            SITE.profileImage && (
                <div class="mb-10">
                    <img
                        src={`/${SITE.profileImage}`}
                        alt={SITE.author}
                        class="w-32 h-32 rounded-full object-cover border-4 border-border shadow-md contrast-110 hover:contrast-125 transition-all duration-300"
                    />
                </div>
            )
        }
        <h1
            class="text-3xl font-extrabold m-0 tracking-tight text-foreground leading-tight"
        >
            {SITE.title}
        </h1>
        <p class="text-[0.9rem] text-text-muted mt-2 font-medium">
            {SITE.institution}
        </p>
        <p
            class="text-[1rem] leading-relaxed mt-10 text-foreground opacity-90 font-medium"
        >
            {SITE.shortBio}
        </p>
    </div>

    <div class="flex flex-col gap-8 max-md:mt-12 items-center">
        <div class="flex gap-5 flex-wrap items-center justify-center">
            {
                activeSocials.map((social) => (
                    <a
                        href={social.href}
                        title={social.linkTitle}
                        target="_blank"
                        rel="noreferrer"
                        class="text-text-muted hover:text-foreground transition-all duration-300 hover:scale-110"
                        set:html={SOCIAL_ICONS[social.name]}
                    />
                ))
            }
        </div>
    </div>
</aside>

<style>
    :global(.social-link svg),
    :global(a svg) {
        width: 20px;
        height: 20px;
        stroke-width: 1.5px;
    }
</style>
