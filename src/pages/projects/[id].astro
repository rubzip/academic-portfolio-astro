---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
    const projects = await getCollection("projects");
    return projects.map((project) => ({
        params: { id: project.id },
        props: { project },
    }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<Layout title={project.data.title}>
    <article class="project-content">
        <header>
            <h1>{project.data.title}</h1>
            {
                project.data.tech && (
                    <div class="tech-stack">
                        {project.data.tech.map((t) => (
                            <span class="tech-tag">{t}</span>
                        ))}
                    </div>
                )
            }
            <p class="description">{project.data.description}</p>
        </header>

        <div class="links">
            {
                project.data.github && (
                    <a href={project.data.github} target="_blank">
                        GitHub Repository &rarr;
                    </a>
                )
            }
        </div>

        <hr />

        <div class="prose">
            <Content />
        </div>
    </article>
</Layout>

<style>
    .project-content {
        max-width: 800px;
        margin: 0 auto;
        padding-top: 2rem;
    }
    header {
        margin-bottom: 3rem;
    }
    h1 {
        font-size: clamp(2.5rem, 5vw, 3.5rem);
        font-weight: 800;
        margin: 0;
        line-height: 1.1;
        letter-spacing: -0.02em;
    }
    .description {
        font-size: 1.2rem;
        margin-top: 1.5rem;
        color: var(--text-muted);
        line-height: 1.5;
        font-weight: 500;
    }
    .tech-stack {
        margin-top: 2rem;
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
    }
    .tech-tag {
        font-size: 0.85rem;
        color: var(--accent);
        font-weight: 700;
        opacity: 0.8;
    }
    .links {
        margin-top: 2rem;
        margin-bottom: 3rem;
    }
    .links a {
        font-weight: 700;
        text-decoration: none;
        color: var(--foreground);
        font-size: 1rem;
        transition: color 0.2s;
    }
    .links a:hover {
        color: var(--accent);
        text-decoration: underline;
    }
    hr {
        border: 0;
        border-top: 1px dashed var(--border);
        margin: 3rem 0;
    }
    .prose {
        line-height: 1.8;
        font-size: 1.1rem;
    }
</style>
