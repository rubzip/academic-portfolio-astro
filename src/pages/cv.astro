---
import { getEntry } from "astro:content";
import Layout from "../layouts/Layout.astro";
import { SITE } from "../config";

const cvEntry = await getEntry("cv", "cv");
if (!cvEntry) {
    throw new Error(
        "CV content not found. Please ensure src/content/cv.md exists.",
    );
}

const { name, experience, education, skills } = cvEntry.data;
---

<Layout title="CV">
    <header class="cv-header">
        <h1>Curriculum Vitae</h1>
    </header>

    <section class="cv-section">
        <h2>Professional Experience</h2>
        <div class="entries">
            {
                experience.map((exp) => (
                    <div class="cv-entry">
                        <div class="entry-header">
                            <h3>{exp.role}</h3>
                            <span class="period">{exp.period}</span>
                        </div>
                        <div class="institution">{exp.institution}</div>
                        <div class="desc">{exp.description}</div>
                    </div>
                ))
            }
        </div>
    </section>

    <section class="cv-section">
        <h2>Education</h2>
        <div class="entries">
            {
                education.map((edu) => (
                    <div class="cv-entry">
                        <div class="entry-header">
                            <h3>{edu.degree}</h3>
                            <span class="period">{edu.period}</span>
                        </div>
                        <div class="institution">{edu.institution}</div>
                        {edu.thesis && (
                            <div class="thesis">
                                <em>Thesis: {edu.thesis}</em>
                            </div>
                        )}
                    </div>
                ))
            }
        </div>
    </section>

    <section class="cv-section">
        <h2>Skills</h2>
        <div class="skills-list">
            {
                skills.map((skill, index) => (
                    <span class="skill-item">
                        {skill}
                        {index < skills.length - 1 ? " • " : ""}
                    </span>
                ))
            }
        </div>
    </section>
</Layout>

<style>
    .cv-header {
        margin-bottom: 3rem;
    }
    h1 {
        font-size: 2.5rem;
        margin-bottom: 0.5rem;
    }
    .cv-section {
        margin-bottom: 3rem;
    }
    h2 {
        font-size: 1.75rem;
        border-bottom: 1px solid var(--border);
        padding-bottom: 0.5rem;
        margin-bottom: 1.5rem;
        letter-spacing: -0.01em;
    }
    .entries {
        display: flex;
        flex-direction: column;
        gap: 2rem;
    }
    .cv-entry {
        display: flex;
        flex-direction: column;
    }
    .entry-header {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
    }
    .cv-entry h3:hover {
        color: var(--accent);
    }
    .period {
        font-size: 0.9rem;
        color: var(--text-muted);
        font-weight: 500;
    }
    .institution {
        font-weight: 600;
        margin: 0.25rem 0;
    }
    .desc,
    .thesis {
        margin-top: 0.5rem;
        line-height: 1.5;
    }
    .skills-list {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem 1rem;
    }
    .skill-item {
        font-weight: 500;
        color: var(--foreground);
    }
</style>
