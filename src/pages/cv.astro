---
import { getEntry } from "astro:content";
import Layout from "../layouts/Layout.astro";
import { SITE } from "../config";

const cvEntry = await getEntry("cv", "cv");
if (!cvEntry) {
    throw new Error(
        "CV content not found. Please ensure src/content/cv.md exists.",
    );
}

const { name, experience, education, skills } = cvEntry.data;
---

<Layout title="CV">
    <header class="cv-header">
        <h1>Curriculum Vitae</h1>
    </header>

    <section class="cv-section">
        <h2>Professional Experience</h2>
        <div class="timeline">
            {
                experience.map((exp) => (
                    <div class="timeline-item">
                        <div class="timeline-marker">
                            <div class="dot" />
                            <div class="line" />
                        </div>
                        <div class="timeline-content">
                            <div class="entry-header">
                                <h3>{exp.role}</h3>
                                <span class="period">{exp.period}</span>
                            </div>
                            <div class="institution">{exp.institution}</div>
                            <div class="desc">{exp.description}</div>
                        </div>
                    </div>
                ))
            }
        </div>
    </section>

    <section class="cv-section">
        <h2>Education</h2>
        <div class="timeline">
            {
                education.map((edu) => (
                    <div class="timeline-item">
                        <div class="timeline-marker">
                            <div class="dot" />
                            <div class="line" />
                        </div>
                        <div class="timeline-content">
                            <div class="entry-header">
                                <h3>{edu.degree}</h3>
                                <span class="period">{edu.period}</span>
                            </div>
                            <div class="institution">{edu.institution}</div>
                            {edu.thesis && (
                                <div class="thesis">
                                    <em>Thesis: {edu.thesis}</em>
                                </div>
                            )}
                        </div>
                    </div>
                ))
            }
        </div>
    </section>

    <section class="cv-section">
        <h2>Skills</h2>
        <div class="skills-list">
            {
                skills.map((skill, index) => (
                    <span class="skill-item">
                        {skill}
                        {index < skills.length - 1 ? " • " : ""}
                    </span>
                ))
            }
        </div>
    </section>
</Layout>

<style>
    .cv-header {
        margin-bottom: 3rem;
    }
    h1 {
        font-size: 2.5rem;
        margin-bottom: 0.5rem;
    }
    .cv-section {
        margin-bottom: 5rem;
    }
    h2 {
        font-size: 1.75rem;
        margin-bottom: 2.5rem;
        font-weight: 800;
        letter-spacing: -0.01em;
        color: var(--foreground);
        opacity: 0.9;
    }
    .timeline {
        display: flex;
        flex-direction: column;
    }
    .timeline-item {
        display: flex;
        gap: 2rem;
    }
    .timeline-marker {
        display: flex;
        flex-direction: column;
        align-items: center;
        flex-shrink: 0;
    }
    .dot {
        width: 12px;
        height: 12px;
        border-radius: 50%;
        background: var(--accent);
        margin-top: 0.5rem;
        z-index: 1;
    }
    .line {
        flex: 1;
        width: 2px;
        background: var(--border);
        margin: 0.5rem 0;
    }
    .timeline-item:last-child .line {
        display: none;
    }
    .timeline-content {
        padding-bottom: 3.5rem;
        flex: 1;
    }
    .timeline-item:last-child .timeline-content {
        padding-bottom: 0;
    }
    .entry-header {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: 1rem;
        margin-bottom: 0.5rem;
    }
    h3 {
        font-size: 1.5rem;
        margin: 0;
        font-weight: 700;
        line-height: 1.2;
        transition: color 0.2s;
    }
    h3:hover {
        color: var(--accent);
    }
    .period {
        font-size: 0.9rem;
        color: var(--text-muted);
        font-weight: 600;
        white-space: nowrap;
    }
    .institution {
        font-weight: 600;
        font-size: 1.1rem;
        color: var(--foreground);
        opacity: 0.9;
    }
    .desc,
    .thesis {
        margin-top: 1rem;
        line-height: 1.6;
        opacity: 0.85;
    }
    .skills-list {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem 1.25rem;
    }
    .skill-item {
        font-weight: 600;
        color: var(--text-muted);
        font-size: 1rem;
    }
</style>
