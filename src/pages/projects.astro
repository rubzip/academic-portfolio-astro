---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";

const projects = await getCollection("projects");
---

<Layout title="Projects">
    <header>
        <h1>Code & Projects</h1>
        <p class="subtitle">
            A selection of technical projects and software experiments.
        </p>
    </header>

    <section class="projects-list">
        {
            projects.map((project) => (
                <article class="project-item">
                    <div class="project-content">
                        <a href={`/projects/${project.id}`} class="title-link">
                            <h3>{project.data.title}</h3>
                        </a>
                        <p>{project.data.description}</p>
                        <div class="tech-stack">
                            {project.data.tech?.map((t, index) => (
                                <span class="tech-item">
                                    {t}
                                    {index <
                                    (project.data.tech?.length ?? 0) - 1
                                        ? " • "
                                        : ""}
                                </span>
                            ))}
                        </div>
                    </div>
                    <div class="project-links">
                        {project.data.github && (
                            <a href={project.data.github} target="_blank">
                                GitHub &rarr;
                            </a>
                        )}
                    </div>
                </article>
            ))
        }
    </section>
</Layout>

<style>
    h1 {
        font-size: 2.5rem;
        margin: 0;
    }
    .subtitle {
        color: var(--text-muted);
        margin-bottom: 3rem;
    }
    .projects-list {
        display: flex;
        flex-direction: column;
        gap: 3rem;
    }
    .project-item {
        padding-bottom: 2rem;
        border-bottom: 1px solid var(--border);
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 2rem;
    }
    .project-item:last-child {
        border-bottom: none;
    }
    .title-link {
        text-decoration: none;
        color: inherit;
    }
    .title-link:hover h3 {
        text-decoration: underline;
        color: var(--accent);
    }
    .project-content h3 {
        margin: 0 0 1rem 0;
        font-size: 1.5rem;
    }
    .tech-stack {
        margin-top: 1rem;
        display: flex;
        gap: 0.5rem 1rem;
        flex-wrap: wrap;
    }
    .tech-item {
        font-size: 0.9rem;
        color: var(--text-muted);
        font-weight: 500;
    }
    .project-links a {
        font-weight: 600;
        text-decoration: none;
        color: inherit;
        font-size: 0.9rem;
    }
    .project-links a:hover {
        opacity: 0.7;
    }
</style>
